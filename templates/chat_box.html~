<div id="chat-container" style="display: flex;">
  <!-- 左侧联系人列表 -->
  <div id="chat-dropdown" class="chat-dropdown" style="width: 250px; border: 1px solid #ccc;">
    <div class="chat-header" style="padding: 10px; font-weight: bold; background: #f5f5f5;">最近聊天</div>
    <ul class="chat-user-list" id="chat-user-list" style="list-style: none; padding: 0; margin: 0;">
      <!-- 动态插入用户 -->
    </ul>
  </div>

  <!-- 右侧聊天窗口 -->
  <div id="chat-window" class="chat-window" style="display:none; width: 500px; border: 1px solid #ccc; margin-left: 10px;">
    <div class="chat-header" style="padding: 10px; background: #f5f5f5; font-weight: bold;">
      与 <span id="chat-user-name"></span> 聊天
    </div>

    <div class="chat-messages" id="chat-messages" style="height: 300px; overflow-y: auto; padding: 10px; background: #fff; border-top: 1px solid #eee; border-bottom: 1px solid #eee;">
      <!-- 动态插入消息 -->
    </div>

    <div class="chat-input" style="display: flex; padding: 10px;">
      <input type="text" id="chat-input-text" placeholder="输入消息..." style="flex: 1; padding: 5px;" />
      <button id="send-message" style="margin-left: 10px;">发送</button>
    </div>
  </div>
</div>
